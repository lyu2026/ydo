{
	"manifest_version":3,
	"name":"译览刀",
	"version":"1.0.0",
	"description":"网页正文 转换为 MD文档，支持中文翻译",
	"permissions":["activeTab","scripting"],
	"host_permissions":["<all_urls>"],
	"background":{"service_worker":"background.js"},
	"action":{
		"default_popup":"poppup.html",
		"default_icon":{
			"36":"icons/36.png",
			"48":"icons/48.png",
			"128":"icons/128.png"
		},
		"default_title":"译览刀"
	},
	"icons":{
		"36":"icons/36.png",
		"48":"icons/48.png",
		"128":"icons/128.png"
	},
	"content_security_policy":{
		"extension_pages":"script-src 'self';object-src 'self'"
	}
}